# ─────────────────────────────────────────────────────────────
# CLIENT-SIDE (safe to expose — bundled into the browser build)
# Anything prefixed with VITE_ is PUBLIC. Never put secrets here.
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary — used by the browser to upload the ORIGINAL image
# directly (unsigned). Cloud name + unsigned upload preset are public.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# ─────────────────────────────────────────────────────────────
# SERVER-SIDE ONLY (used by /api functions — NEVER prefixed VITE_)
# In production set these in the Vercel dashboard (Project → Settings
# → Environment Variables). For local `vercel dev`, put them in
# .env.local (which is gitignored).
# ─────────────────────────────────────────────────────────────
CLIPDROP_API_KEY=your-clipdrop-api-key

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# The API functions talk to Supabase using the same project URL.
# The anon key is enough because we forward the signed-in user's JWT,
# so Row Level Security still applies. (No service-role key required.)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
